function WatercolorCoach(){
const [mode,setMode]=useState(“choice”);
const [subject,setSubject]=useState(””);
const [photoData,setPhotoData]=useState(null);
const [photoPreview,setPhotoPreview]=useState(null);
const [guidance,setGuidance]=useState(null);
const [currentStage,setCurrentStage]=useState(0);
const [error,setError]=useState(null);
const [debugRaw,setDebugRaw]=useState(””);
const fileRef=React.useRef();

function reset(){setMode(“choice”);setGuidance(null);setPhotoData(null);setPhotoPreview(null);setSubject(””);setCurrentStage(0);setError(null);}

function handlePhoto(e){
const file=e.target.files?.[0];
if(!file)return;
const reader=new FileReader();
reader.onload=ev=>{
const dataUrl=ev.target.result;
setPhotoPreview(dataUrl);
setPhotoData(dataUrl.split(”,”)[1]);
};
reader.readAsDataURL(file);
}

function buildLocalGuidance(desc){
const d=desc.toLowerCase();
const isLeaf=d.includes(“leaf”)||d.includes(“leaves”);
const isFlower=d.includes(“flower”)||d.includes(“petal”)||d.includes(“bloom”)||d.includes(“blossom”);
const isFeather=d.includes(“feather”);
const isShell=d.includes(“shell”)||d.includes(“snail”)||d.includes(“spiral”);
const isBark=d.includes(“bark”)||d.includes(“wood”)||d.includes(“branch”)||d.includes(“twig”);
