</div>
)}
{/* Opening prompt */}
{exchanges.length===0&&<div style={{background:“var(–sage-bg)”,borderRadius:8,padding:“9px 11px”,marginBottom:”.75rem”,fontSize:”.9rem”,color:“var(–navy)”}}>{randPrompt}</div>}
{/* Exchange history */}
{exchanges.map((e,i)=>(
<div key={i}>
{!e.isPhotoStart&&(
<div style={{background:“var(–cream)”,border:“1px solid var(–sage-bg)”,borderRadius:“8px 8px 0 0”,padding:“8px 11px”,marginBottom:2}}>
<div style={{fontFamily:”‘Lato’,sans-serif”,fontSize:”.6rem”,textTransform:“uppercase”,color:“var(–muted)”,marginBottom:2}}>{levelLabels[e.level]||””}</div>
