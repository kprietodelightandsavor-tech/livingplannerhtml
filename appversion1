const weeklyHrs=Object.values(ohDays).reduce((s,v)=>s+(parseFloat(v)||0),0);
const ohGoal=outdoorHours?.goal||15;

// Habit streak
const habitStreak=(()=>{if(!habit)return 0;let s=0;const d=new Date();while(true){const k=d.toLocaleDateString(“en-US”,{month:“short”,day:“numeric”,year:“numeric”});if(habitLog?.[k]?.done){s++;d.setDate(d.getDate()-1);}else break;}return s;})();

// Today’s loop
const todayLoopItem=beautyLoop[0]?.days?.[td]||null;

// Dashboard row — shown in both modes
function DashRow(){
return(
<div style={{display:“flex”,gap:8,marginBottom:”.9rem”}}>
<DashCard
accent=“sage”
icon={<IcoCardSun/>}
label={“Outside This\nWeek”}
value={weeklyHrs>0?(weeklyHrs%1===0?weeklyHrs:weeklyHrs.toFixed(1))+“h”:null}
sub={weeklyHrs>0?`of ${ohGoal}h goal`:null}
action={true}
actionLabel=”+ Log Time”
onClick={()=>onNav(“outdoor”)}
/>
<DashCard
accent=“sage”
icon={<IcoCardLoop/>}
label=“Today’s Loop”
value={null}
sub={todayLoopItem||“Set up loop”}
onClick={()=>onNav(“planner”)}
/>
<DashCard
accent=“gold”
icon={<IcoCardHabit/>}
label=“Habit”
value={habitStreak>0?habitStreak:null}
sub={habit?.name||“No habit set”}
action={true}
actionLabel=”+ Check In”
onClick={()=>onNav(“habits”)}
/>
</div>
);
}

if(mode===“student”){
const [subjectChecked,setSubjectChecked]=useState({});
const doneCount=todaySched.filter(s=>subjectChecked[s.id]).length;
const allDone=todaySched.length>0&&doneCount===todaySched.length;
const hr=new Date().getHours();
const child=children[0];
return(
<div>
<div style={{textAlign:“center”,padding:”.5rem 0 .75rem”}}>
<div style={{fontSize:“2rem”,marginBottom:”.25rem”}}>{allDone?“✦”:hr<12?“◎”:“◉”}</div>
<h1 style={{fontFamily:”‘Playfair Display’,serif”,fontSize:“clamp(1.3rem,5vw,1.8rem)”,color:“var(–navy)”}}>{allDone?“All done!”:(hr<12?“Good morning”:“Good afternoon”)+”, “+(child?.name||“friend”)}</h1>
<p style={{color:“var(–muted)”,fontStyle:“italic”,fontSize:”.88rem”,marginTop:2}}>{td} · {doneCount} of {todaySched.length} subjects done</p>
</div>
<DashRow/>
<RiseAndShinePanel rsItems={rsItems} setRsItems={()=>{}} rsChecked={rsChecked} setRsChecked={setRsChecked} mode=“student”/>
{todaySched.length>0&&(
<div className="card">
<div className="card-hdr"><div className="card-icon ci-sage"><IcoCardSchedule/></div><div><div className="card-ttl">School Day</div><div className="card-sub">{doneCount} of {todaySched.length} complete</div></div></div>
<div className=“card-body” style={{padding:”.75rem 1rem”}}>
<div style={{background:“var(–sage-bg)”,borderRadius:20,height:6,marginBottom:10,overflow:“hidden”}}><div style={{height:“100%”,borderRadius:20,background:allDone?“var(–gold)”:“var(–sage)”,width:`${todaySched.length?(doneCount/todaySched.length)*100:0}%`,transition:“width .4s ease”}}/></div>
{todaySched.map((s,i)=>(
<div key={s.id||i} onClick={()=>setSubjectChecked(p=>({…p,[s.id]:!p[s.id]}))} style={{display:“flex”,alignItems:“center”,gap:10,padding:“10px 0”,borderBottom:i<todaySched.length-1?“1px solid var(–sage-bg)”:“none”,cursor:“pointer”,opacity:subjectChecked[s.id]?.5:1}}>
<div style={{width:26,height:26,borderRadius:7,flexShrink:0,border:`2px solid ${subjectChecked[s.id]?"var(--sage)":"#ddd8ce"}`,background:subjectChecked[s.id]?“var(–sage)”:“transparent”,display:“flex”,alignItems:“center”,justifyContent:“center”,fontSize:”.9rem”,color:”#fff”}}>{subjectChecked[s.id]&&“✓”}</div>
<div style={{flex:1}}>
<div style={{fontFamily:”‘Playfair Display’,serif”,fontSize:”.95rem”,color:subjectChecked[s.id]?“var(–muted)”:“var(–navy)”,textDecoration:subjectChecked[s.id]?“line-through”:“none”}}>{s.subject}</div>
{s.planned&&!subjectChecked[s.id]&&<div style={{fontFamily:”‘Lato’,sans-serif”,fontSize:”.68rem”,color:“var(–muted)”,fontStyle:“italic”,marginTop:1}}>{s.planned}</div>}
</div>
</div>
))}
</div>
</div>
)}
