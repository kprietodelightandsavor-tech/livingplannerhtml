function uid(){return Date.now()+Math.random().toString(36).slice(2,7);}
function buildLoop(enrichments,schoolDays,weeks=12,perDay=null){
if(!schoolDays.length)return[];
const dayLists={};
if(perDay&&Object.keys(perDay).length>0){
for(const d of schoolDays){dayLists[d]=perDay[d]||[];}
} else {
if(!enrichments.length)return[];
let idx=0;for(const d of schoolDays){dayLists[d]=[enrichments[idx%enrichments.length]];idx++;}
}
const idxMap={};for(const d of schoolDays)idxMap[d]=0;
const result=[];
for(let w=1;w<=weeks;w++){
const week={week:w,days:{}};
for(const d of schoolDays){
const list=dayLists[d];
if(list&&list.length>0){week.days[d]=list[idxMap[d]%list.length];idxMap[d]++;}
else{week.days[d]=null;}
}
result.push(week);
}
return result;
}
