)}
{/* Input */}
{exchanges.length<(photoExtracted?2:3)&&(
<div className="field" style={{marginBottom:0}}>
<textarea placeholder={level===“find”?“Tell me what you read…”:level===“follow”?“What thread do you notice…”:“What does this connect to…”} value={narText} onChange={e=>setNarText(e.target.value)} style={{minHeight:80}}/>
</div>
)}
{exchanges.length>=(photoExtracted?2:3)&&(
<div style={{background:“var(–sage-bg)”,borderRadius:8,padding:“9px 11px”,textAlign:“center”,fontStyle:“italic”,color:“var(–sage)”,fontSize:”.88rem”}}>You’ve moved through all three levels. Beautiful work.</div>
)}
</div>
<div className="card-foot">
{exchanges.length<(photoExtracted?2:3)&&<button className="btn btn-gold" onClick={submit} disabled={!narText.trim()||loading}>{loading?<><span className="spin"/> Coaching…</>:level===“find”?“Submit & Follow It”:level===“follow”?“Submit & Frame It”:“Submit”}</button>}
{exchanges.length>=(photoExtracted?2:3)&&<button className="btn btn-sage" onClick={finish}>Save Session</button>}
<button className="btn btn-ghost btn-sm" onClick={reset}>Cancel</button>
</div>
</div>
)}
{step===“done”&&<div className="card"><div className=“card-body” style={{textAlign:“center”,padding:“1.75rem 1rem”}}><div style={{fontSize:“1.5rem”,color:“var(–sage)”}}>✦</div><h2 style={{color:“var(–navy)”}}>Well done.</h2><p style={{color:“var(–muted)”,fontStyle:“italic”}}>Session saved.</p></div><div className=“card-foot” style={{justifyContent:“center”}}><button className="btn btn-gold" onClick={reset}>New Session</button></div></div>}
</>)}
{tab===“history”&&(<div>{narrations.length>0?narrations.slice().reverse().map((n,i)=>(<div key={i} className=“he” style={{background:“var(–white)”,borderRadius:9,padding:“10px 12px”,marginBottom:7,border:“1.5px solid var(–sage-bg)”}}><div className="he-row"><span className="he-ttl">{n.book}</span><span className="he-date">{n.date}</span></div><div className="he-meta">{n.studentName}</div><div className="he-pre">{n.narrationText?.slice(0,90)}…</div></div>)):<div className="empty"><div className=“empty-icon” style={{color:“var(–gold)”}}><IcoCardNarrate/></div><p>No sessions yet.</p></div>}</div>)}
</div>
);
}

