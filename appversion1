{photoLoading&&<div style={{textAlign:“center”,padding:“1rem”,fontFamily:”‘Cormorant Garamond’,serif”,fontStyle:“italic”,color:“var(–muted)”}}>Reading narration… <span className="spin"/></div>}
</div>
)}
</div>
{!photoMode&&<div className="card-foot"><button className="btn btn-gold" onClick={start} disabled={!customBook}>Begin Session</button></div>}
</div>
)}
{step===“session”&&(
<div className="card">
<div className="card-hdr">
<div className="card-icon ci-gold"><IcoCardNarrate/></div>
<div style={{flex:1}}>
<div className="card-ttl">{customBook}</div>
<div className="card-sub">{child?.name}{childForm&&` · ${childForm.split("(")[0].trim()}`} · {readType}</div>
</div>
<div style={{display:“flex”,gap:3}}>
{[“find”,“follow”,“frame”].map(l=>(
<div key={l} style={{width:9,height:9,borderRadius:“50%”,background:exchanges.find(e=>e.level===l&&!e.isPhotoStart)?“var(–sage)”:level===l?“var(–gold)”:”#ddd8ce”}}/>
