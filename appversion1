const [readType,setReadType]=useState(“Independent”);
const [level,setLevel]=useState(“find”);
const [narText,setNarText]=useState(””);
const [exchanges,setExchanges]=useState([]);
const [loading,setLoading]=useState(false);
const [allNarText,setAllNarText]=useState(””);
// Photo narration
const [photoMode,setPhotoMode]=useState(false);
const [photoData,setPhotoData]=useState(null);
const [photoLoading,setPhotoLoading]=useState(false);
const [photoExtracted,setPhotoExtracted]=useState(””);

const LEVEL_ORDER=[“find”,“follow”,“frame”];
const nextLevel=l=>LEVEL_ORDER[LEVEL_ORDER.indexOf(l)+1]||null;
const child=children.find(c=>c.id===childId)||children[0];
const childForm=child?.form||””;
const randPrompt=OPEN_PROMPTS[Math.floor(Math.random()*OPEN_PROMPTS.length)];

// Form-specific question prompts
const FORM_SYSTEM={
“Form I (Grades 1–3)”:{
follow:“You are coaching a young child (grades 1–3, Charlotte Mason Form I). After reading their narration, ask ONE gentle follow-up question to help them go deeper — keep it simple, warm, and concrete. Focus on what happened, who was in the story, or what the child noticed. No more than 2 sentences.”,
frame:“Now ask this young child ONE connecting question — can they think of something from their own life or another story that reminds them of what they read? Keep it playful and short.”,
},
“Form II (Grades 4–6)”:{
follow:“You are coaching a Form II student (grades 4–6, Charlotte Mason). After reading their narration, ask ONE follow-up question to help them notice a pattern, cause-and-effect, or character motivation in what they read. Be warm and Socratic.”,
frame:“Now ask ONE framing question — help this student connect what they read to a big idea, another book, or something happening in the world. One question only.”,
},
“Form III (Grades 7–9)”:{
follow:“You are coaching a Form III student (grades 7–9, Charlotte Mason). After reading their narration, ask ONE pointed follow-up: press them on an assumption, a character’s motive, or an ambiguity in the text. Be intellectually respectful.”,
frame:“Now ask ONE synthesis question — push this student to articulate the theme, tension, or argument of the passage, or connect it to what they already know from history, philosophy, or other literature.”,
},
“Form IV–VI (Grades 10–12)”:{
follow:“You are coaching a senior Form student (grades 10–12, Charlotte Mason). After reading their narration, ask ONE rigorous follow-up question that probes the text’s logic, rhetoric, or moral claims. Assume genuine intellectual ability.”,
frame:“Now ask ONE essay-level framing question — something this student could write about. It should demand synthesis, argument, or original judgment about the work.”,
},
};
function getFormSys(lvl){
const f=FORM_SYSTEM[childForm];
if(!f)return lvl===“follow”?FORM_SYSTEM[“Form II (Grades 4–6)”].follow:FORM_SYSTEM[“Form II (Grades 4–6)”].frame;
return lvl===“follow”?f.follow:f.frame;
}

function start(){if(!customBook)return;setStep(“session”);setExchanges([]);setLevel(“find”);setNarText(””);setAllNarText(””);setPhotoData(null);setPhotoExtracted(””);setPhotoMode(false);}

async function handlePhoto(e){
const file=e.target.files[0];if(!file)return;
setPhotoLoading(true);
const base64=await new Promise(res=>{const r=new FileReader();r.onload=()=>res(r.result.split(”,”)[1]);r.readAsDataURL(file);});
setPhotoData(base64);
// Send to Claude vision to extract + begin session
try{
const resp=await fetch(“https://api.anthropic.com/v1/messages”,{method:“POST”,headers:{“Content-Type”:“application/json”},body:JSON.stringify({
model:“claude-sonnet-4-20250514”,max_tokens:1000,
system:“You are a Charlotte Mason narration coach. The student has submitted a handwritten narration. Read the image carefully and extract what they wrote. Then respond with ONLY a JSON object with two keys: ‘extracted’ (the verbatim or closely paraphrased text from the image) and ‘findQ’ (one warm, open-ended Find It question to start the coaching session — e.g. ‘You mentioned __. Can you tell me more about that part?’). Output only valid JSON, no markdown.”,
messages:[{role:“user”,content:[
{type:“image”,source:{type:“base64”,media_type:file.type||“image/jpeg”,data:base64}},
{type:“text”,text:`This is a written narration for: "${customBook}". Extract the text and generate the first Find It question.`}
]}]
})});
const data=await resp.json();
const raw=data.content[0].text;
const parsed=JSON.parse(raw.replace(/`json|`/g,””).trim());
setPhotoExtracted(parsed.extracted||””);
setAllNarText(parsed.extracted||””);
setExchanges([{level:“find”,narration:”[Photo narration — see extracted text below]”,coachReply:parsed.findQ||“Tell me more about what you read.”,isPhotoStart:true,extracted:parsed.extracted}]);
setLevel(“follow”);
setStep(“session”);
}catch(err){
setPhotoExtracted(“Could not read image — please type your narration below.”);
setStep(“session”);
}
setPhotoLoading(false);
}

async function submit(){
if(!narText.trim())return;
setLoading(true);
const isFollow=level===“follow”;
const systemPrompt=getFormSys(isFollow?“follow”:“frame”);
const context=exchanges.map(e=>`Student: ${e.narration}\nCoach: ${e.coachReply}`).join(”\n\n”);
const userMsg=`Book/subject: ${customBook}\n\nNarration so far:\n${allNarText}\n\n${context?`Previous exchange:\n${context}\n\n`:""}Student's new response:\n${narText}`;
try{
const resp=await fetch(“https://api.anthropic.com/v1/messages”,{method:“POST”,headers:{“Content-Type”:“application/json”},body:JSON.stringify({
model:“claude-sonnet-4-20250514”,max_tokens:300,
system:systemPrompt,
messages:[{role:“user”,content:userMsg}]
})});
const data=await resp.json();
const reply=data.content[0].text;
setExchanges(p=>[…p,{level,narration:narText,coachReply:reply}]);
setAllNarText(p=>p+(p?” | “:””)+narText);
setNarText(””);
const nl=nextLevel(level);
if(nl)setLevel(nl);
}catch{
const pool=MOCK_RESPONSES[level];
const reply=pool[Math.floor(Math.random()*pool.length)];
setExchanges(p=>[…p,{level,narration:narText,coachReply:reply}]);
setAllNarText(p=>p+(p?” | “:””)+narText);
setNarText(””);
const nl=nextLevel(level);
if(nl)setLevel(nl);
}
setLoading(false);
}

function finish(){setNarrations(p=>[…p,{id:uid(),studentName:child?.name||“Student”,childId,book:customBook,readType,narrationText:allNarText,exchanges,date:todayStr()}]);setStep(“done”);}
