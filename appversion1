function OutdoorTimeScreen({outdoorHours,setOutdoorHours,mode}){
const [editingDay,setEditingDay]=useState(null);
const [draftVal,setDraftVal]=useState(””);
const [editGoal,setEditGoal]=useState(false);
const [draftGoal,setDraftGoal]=useState(””);
const wk=getWeekKey();
const days=outdoorHours?.days?.[wk]||{};
const goal=outdoorHours?.goal||10;
const weeklyTotal=Object.values(days).reduce((s,v)=>s+(parseFloat(v)||0),0);
const td=todayStr();
const todayHrs=days[td]||0;
const pct=Math.min(weeklyTotal/goal,1);
const r=54;const circ=2*Math.PI*r;
const PROMPTS=[“Find one thing you’ve never noticed before in your usual spot.”,“Sit still for 5 minutes and write down everything you hear.”,“Sketch one plant from observation — roots to tip if possible.”,“Count the kinds of birds you see or hear.”,“Look for signs of change — what is different from last week?”,“Find water. Watch it for five full minutes.”];
const randPrompt=PROMPTS[new Date().getDate()%PROMPTS.length];
function setDayHours(dateStr,val){const num=parseFloat(val);setOutdoorHours(prev=>({…prev,days:{…(prev.days||{}),[wk]:{…(prev.days?.[wk]||{}),[dateStr]:isNaN(num)?0:num}}}));}
function saveGoal(){const num=parseFloat(draftGoal);if(!isNaN(num)&&num>0)setOutdoorHours(p=>({…p,goal:num}));setEditGoal(false);}
const last7=Array.from({length:7},(_,i)=>{const d=new Date();d.setDate(d.getDate()-(6-i));return{label:d.toLocaleDateString(“en-US”,{weekday:“short”}),dateStr:d.toLocaleDateString(“en-US”,{month:“short”,day:“numeric”,year:“numeric”}),isToday:d.toLocaleDateString(“en-US”,{month:“short”,day:“numeric”,year:“numeric”})===td};});
return(
<div>
<div style={{marginBottom:“1rem”}}><h2 style={{color:“var(–navy)”}}>Outdoor Time</h2><p style={{color:“var(–muted)”,fontStyle:“italic”,fontSize:”.91rem”}}>Charlotte Mason required outdoor time daily — rain or shine.</p></div>
<div className="cm-tip"><div className="cm-tip-lbl">✦ Mason’s standard</div><p>Three to six hours of outdoor time per day for young children. For older students, at least 20 minutes of sustained nature attention — not just play.</p></div>
<div className="card">
<div className="card-hdr">
<div className="card-icon ci-sage"><IcoCardLeaf/></div>
<div style={{flex:1}}><div className="card-ttl">This Week’s Outdoor Hours</div><div className="card-sub">Tap any day to edit</div></div>
<div style={{display:“flex”,alignItems:“center”,gap:5}}>
{editGoal?(
<><input autoFocus value={draftGoal} onChange={e=>setDraftGoal(e.target.value)} onKeyDown={e=>e.key===“Enter”&&saveGoal()} style={{width:50,border:“1.5px solid var(–sage)”,borderRadius:6,padding:“3px 6px”,fontFamily:”‘Lato’,sans-serif”,fontSize:”.8rem”,textAlign:“center”,background:“var(–cream)”,outline:“none”}}/><button className="btn btn-sage btn-xs" onClick={saveGoal}>✓</button></>
):(
<button className=“btn btn-ghost btn-xs” onClick={()=>{setDraftGoal(String(goal));setEditGoal(true);}}>Goal: {goal}h</button>
)}
</div>
</div>
<div className="card-body">
<div style={{display:“flex”,alignItems:“center”,gap:“1.2rem”,marginBottom:“1.1rem”}}>
<div className="outdoor-ring">
<svg width=“140” height=“140” viewBox=“0 0 140 140” style={{transform:“rotate(-90deg)”}}>
<circle cx="70" cy="70" r={r} fill="none" stroke="var(--sage-bg)" strokeWidth="10"/>
<circle cx="70" cy="70" r={r} fill="none" stroke={pct>=1?“var(–gold)”:“var(–sage)”} strokeWidth=“10” strokeDasharray={circ} strokeDashoffset={circ*(1-pct)} strokeLinecap=“round” style={{transition:“stroke-dashoffset .5s ease”}}/>
</svg>
<div className="outdoor-ring-center">
<div className="outdoor-ring-hrs">{weeklyTotal%1===0?weeklyTotal:weeklyTotal.toFixed(1)}</div>
<div className="outdoor-ring-lbl">of {goal}h</div>
</div>
</div>
<div style={{flex:1}}>
<div style={{fontFamily:”‘Playfair Display’,serif”,fontSize:“1rem”,color:“var(–navy)”,marginBottom:4}}>{pct>=1?“✦ Goal reached!”:`${(goal-weeklyTotal).toFixed(1)}h to go`}</div>
<div style={{fontFamily:”‘Lato’,sans-serif”,fontSize:”.72rem”,color:“var(–muted)”,lineHeight:1.5}}>Today: <strong style={{color:“var(–navy)”}}>{todayHrs}h</strong></div>
<div style={{fontFamily:”‘Lato’,sans-serif”,fontSize:”.7rem”,color:“var(–muted)”,marginTop:2}}>Tap any bar to edit.</div>
</div>
</div>
<div style={{display:“grid”,gridTemplateColumns:“repeat(7, 1fr)”,gap:5}}>
{last7.map(({label,dateStr,isToday})=>{
const hrs=parseFloat(days[dateStr])||0;
const barPct=Math.min(hrs/Math.max(goal/5,2),1);
const isEditing=editingDay===dateStr;
return(
<div key={dateStr} style={{display:“flex”,flexDirection:“column”,alignItems:“center”,gap:4}}>
<div onClick={()=>{if(!isEditing){setEditingDay(dateStr);setDraftVal(hrs>0?String(hrs):””);}}} style={{width:“100%”,height:52,borderRadius:6,background:“var(–sage-bg)”,position:“relative”,cursor:“pointer”,overflow:“hidden”,outline:isToday?“2px solid var(–gold)”:isEditing?“2px solid var(–sage)”:“none”,outlineOffset:1}}>
<div style={{position:“absolute”,bottom:0,left:0,right:0,height:`${barPct*100}%`,background:pct>=1?“var(–gold)”:“var(–sage)”,borderRadius:“4px 4px 0 0”,transition:“height .4s ease”}}/>
<div style={{position:“absolute”,inset:0,display:“flex”,alignItems:“center”,justifyContent:“center”,fontFamily:”‘Lato’,sans-serif”,fontSize:”.6rem”,fontWeight:700,color:hrs>0.3?“var(–white)”:“var(–muted)”,zIndex:1}}>{hrs>0?`${hrs}h`:””}</div>
</div>
{isEditing?(
<input autoFocus value={draftVal} onChange={e=>setDraftVal(e.target.value)} onBlur={()=>{setDayHours(dateStr,draftVal);setEditingDay(null);}} onKeyDown={e=>{if(e.key===“Enter”){setDayHours(dateStr,draftVal);setEditingDay(null);}if(e.key===“Escape”)setEditingDay(null);}} placeholder=“0” style={{width:“100%”,textAlign:“center”,border:“1.5px solid var(–sage)”,borderRadius:5,padding:“2px 0”,fontFamily:”‘Lato’,sans-serif”,fontSize:”.72rem”,background:“var(–cream)”,outline:“none”}}/>
):(
<div style={{fontFamily:”‘Lato’,sans-serif”,fontSize:”.62rem”,color:isToday?“var(–gold)”:“var(–muted)”,fontWeight:isToday?700:400,textAlign:“center”}}>{label}</div>
)}
</div>
);
})}
</div>
<div style={{fontFamily:”‘Lato’,sans-serif”,fontSize:”.65rem”,color:“var(–muted)”,fontStyle:“italic”,marginTop:8,textAlign:“center”}}>Tap a bar · type hours · press Enter</div>
</div>
</div>
<div className="card">
<div className="card-hdr"><div className="card-icon ci-sage"><IcoCardLeaf/></div><div><div className="card-ttl">Nature Prompt</div><div className="card-sub">For today’s outdoor time</div></div></div>
<div className="card-body"><div style={{fontFamily:”‘Cormorant Garamond’,serif”,fontSize:“1.05rem”,color:“var(–navy)”,fontStyle:“italic”,lineHeight:1.6,padding:“4px 0”}}>{randPrompt}</div></div>
<div className="card-foot"><a className="btn btn-sage btn-sm" href="https://delightandsavor.com" target="_blank">Nature Study Resources</a></div>
</div>
</div>
);
}

