{childForm&&<div style={{background:“var(–sage-bg)”,borderRadius:8,padding:“7px 10px”,marginBottom:10,fontFamily:”‘Lato’,sans-serif”,fontSize:”.68rem”,color:“var(–sage)”}}>✦ Questions will be tailored for <strong>{childForm}</strong></div>}
<div className="field"><label>Reading Type</label><div className="pills">{READ_TYPES.map(t=><span key={t} className={`pill ${readType===t?"gold-on":""}`} onClick={()=>setReadType(t)}>{t}</span>)}</div></div>
<div className="field"><label>Book / Subject</label><input placeholder=“Book title or subject” value={customBook} onChange={e=>setCustomBook(e.target.value)}/></div>
{customBook&&(
