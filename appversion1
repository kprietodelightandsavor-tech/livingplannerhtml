async function getGuidance(usePhoto){
setMode(“loading”); setError(null); setDebugRaw(””);
// Try API first, fall back to local guidance
const SYS=“You are a watercolor teacher. Respond with ONLY a JSON object — no markdown, no backticks. Keys: subject_note (string), sketch {title,steps[],tip}, refine {title,steps[],tip}, paint {title,steps[],tip,palette[3]}. Be specific to the exact subject shown or described.”;
try{
const body={
model:“claude-sonnet-4-20250514”,
max_tokens:1500,
system:SYS,
messages: usePhoto&&photoData
? [{role:“user”,content:[{type:“image”,source:{type:“base64”,media_type:“image/jpeg”,data:photoData}},{type:“text”,text:“Coach me to watercolor this specific subject.”}]}]
: [{role:“user”,content:“Coach me to watercolor: “+subject}]
};
const res=await fetch(“https://api.anthropic.com/v1/messages”,{method:“POST”,headers:{“Content-Type”:“application/json”},body:JSON.stringify(body)});
const txt=await res.text();
const data=JSON.parse(txt);
if(!data.error&&data.content&&data.content.length){
const raw=data.content.map(b=>b.text||””).join(””).trim();
const s=raw.indexOf(”{”), e=raw.lastIndexOf(”}”);
if(s!==-1&&e>s){
const parsed=JSON.parse(raw.slice(s,e+1));
if(parsed.sketch&&parsed.paint){
setGuidance(parsed); setCurrentStage(0); setMode(“guide”);
return;
}
}
}
}catch(e){ console.log(“API unavailable, using local guidance”); }
// Local fallback — always works
const local=buildLocalGuidance(usePhoto?“a nature subject from the photo”:subject);
setGuidance(local); setCurrentStage(0); setMode(“guide”);
}

